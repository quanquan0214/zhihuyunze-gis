def QueryData(username, db_path = 'D:\\A_Pylake\\SQLite\\pylake.db'):
    # 连接到 SQLite 数据库
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    try:
        query_sql = """SELECT password FROM Users WHERE username = '"""+ username +"';"
        cursor.execute(query_sql)
        result = cursor.fetchone()
        # 提交更改
        conn.commit()
        print("Success Query")
        #关闭连接
        conn.close()
        return result[0]
    except :
        print("Not Found Anything")
        # 关闭连接
        conn.close()
        return -1

