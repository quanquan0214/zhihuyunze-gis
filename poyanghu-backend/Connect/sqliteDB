#下面的register和login函数都是用于前端验证
import sqlite3

def CreateUsers(db_path='D:\\A_Pylake\\SQLite\\pylake.db'):
    # 连接到 SQLite 数据库
    conn = sqlite3.connect(db_path)
    print("连接数据库成功。")
    cursor = conn.cursor()
    try:
        # 创建表
        create_table_sql = """
            CREATE TABLE IF NOT EXISTS Users (
                username varchar(64) not null primary key,
                email varchar(64) not null,
                password varchar(64) not null
            );
            """
        cursor.execute(create_table_sql)
        # 提交更改
        conn.commit()
        print("Users表创建完毕。")
        # 关闭连接
        conn.close()
        print("数据库已关闭。")
    except:
        print("Users表已经存在，请不要重复创建。")
        # 关闭连接
        conn.close()
        print("数据库已关闭。")

